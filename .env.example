# ─────────────────────────────────────────
#  PANUOZZO — Variables d'environnement
#  Copier ce fichier en .env et remplir
# ─────────────────────────────────────────

# === STRIPE (obligatoire) ===
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ID du coupon promo (optionnel — créé automatiquement au 1er démarrage,
# puis copier ici la valeur affichée dans les logs pour éviter un nouveau coupon à chaque restart)
PROMO_COUPON_ID=

# === SITE (obligatoire) ===
SITE_URL=https://panuozzo-bougival.fr

# === AUTHENTIFICATION (obligatoire) ===
TABLETTE_PASSWORD=mot_de_passe_tablette
ADMIN_PASSWORD=mot_de_passe_admin

# === SERVEUR (optionnel) ===
PORT=3005

# === EMAIL SMTP (optionnel — emails clients désactivés si absent) ===
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=contact@panuozzo-bougival.fr
SMTP_PASS=mot_de_passe_smtp
ADMIN_EMAIL=admin@panuozzo-bougival.fr

# === IMPRIMANTE THERMIQUE ESC/POS (optionnel) ===
PRINTER_HOST=192.168.1.x
PRINTER_PORT=9100

# === SMS TWILIO (optionnel — désactivé si absent) ===
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE=+33xxxxxxxxx

# === MY THAI (optionnel — proxy interne) ===
MYTHAI_PORT=3006
MYTHAI_ADMIN_PASSWORD=
